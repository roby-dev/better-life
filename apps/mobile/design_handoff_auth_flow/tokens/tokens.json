{
  "$schema": "design-tokens.v1",
  "feature": "auth_flow",
  "device-target": { "width": 390, "height": 844, "model": "iPhone 14 Pro reference" },

  "colors": {
    "brand": {
      "lavender-100": "#C6C6F0",
      "lavender-200": "#A7A7CC",
      "lavender-300": "#8686A3",
      "lavender-400": "#64647A",
      "lavender-500": "#434352"
    },
    "light": {
      "bg-top":     "#FFFFFF",
      "bg-bottom":  "#F4F2F8",
      "surface":    "#FFFFFF",
      "text":       "#434352",
      "text-muted": "rgba(67, 67, 82, 0.55)",
      "text-faint": "rgba(67, 67, 82, 0.40)",
      "border":     "rgba(67, 67, 82, 0.10)",
      "border-focus": "#64647A",
      "icon-idle":  "rgba(100, 100, 122, 0.55)",
      "icon-focus": "#64647A",
      "halo":       "#C6C6F0",
      "primary-bg": "#434352",
      "primary-fg": "#FFFFFF",
      "primary-bg-disabled": "rgba(67, 67, 82, 0.18)",
      "track":      "rgba(67, 67, 82, 0.08)"
    },
    "dark": {
      "bg-top":     "#16151F",
      "bg-bottom":  "#0E0D16",
      "bg-radial-center": "#1F1E2C",
      "surface":    "rgba(255, 255, 255, 0.04)",
      "text":       "#E6E5F2",
      "text-muted": "rgba(232, 231, 245, 0.55)",
      "text-faint": "rgba(232, 231, 245, 0.40)",
      "border":     "rgba(198, 198, 240, 0.10)",
      "border-focus": "#A7A7CC",
      "icon-idle":  "rgba(232, 231, 245, 0.45)",
      "icon-focus": "#C6C6F0",
      "halo":       "#A7A7CC",
      "primary-bg": "#C6C6F0",
      "primary-fg": "#434352",
      "primary-bg-disabled": "rgba(198, 198, 240, 0.18)",
      "track":      "rgba(198, 198, 240, 0.10)"
    },
    "semantic": {
      "danger":  "#E26B7C",
      "warning": "#D9A95B",
      "success-light": "#64647A",
      "success-dark":  "#C6C6F0"
    },
    "strength-meter": {
      "1": "#E26B7C",
      "2": "#D9A95B",
      "3": "#8686A3",
      "4-light": "#64647A",
      "4-dark":  "#C6C6F0"
    }
  },

  "typography": {
    "family":   "Plus Jakarta Sans",
    "fallback": ["Inter", "system-ui", "sans-serif"],
    "scale": {
      "h1":       { "size": 30, "weight": 800, "tracking": "-0.03em", "line-height": 1.1 },
      "wordmark": { "size": 40, "weight-better": 800, "weight-life": 500, "tracking": "-0.02em" },
      "body":     { "size": 15, "weight": 400, "line-height": 1.5,  "tracking": "-0.005em" },
      "field":    { "size": 16, "weight": 500, "tracking": "-0.005em" },
      "button":   { "size": 16, "weight": 700, "tracking": "-0.005em" },
      "label":    { "size": 11, "weight": 600, "tracking": "0.14em", "transform": "uppercase" },
      "caption":  { "size": 12, "weight": 500, "line-height": 1.5 },
      "tagline":  { "size": 10, "weight": 500, "tracking": "0.32em", "transform": "uppercase", "opacity": 0.7 },
      "link":     { "size": 14, "weight": 700, "tracking": "-0.005em" }
    }
  },

  "spacing": {
    "screen-padding-x": 28,
    "screen-padding-top": 54,
    "screen-padding-bottom": 40,
    "section-gap": 28,
    "field-gap": 18,
    "form-button-gap": 28,
    "stack-gap": 28
  },

  "radius": {
    "field": 14,
    "button": 14,
    "icon-button": 12,
    "pill": 999
  },

  "elevation": {
    "primary-idle-light":   "0 4px 14px rgba(67, 67, 82, 0.12)",
    "primary-hover-light":  "0 10px 28px rgba(67, 67, 82, 0.25)",
    "primary-idle-dark":    "0 4px 14px rgba(198, 198, 240, 0.18)",
    "primary-hover-dark":   "0 10px 28px rgba(198, 198, 240, 0.30)",
    "field-focus-ring-light": "0 0 0 4px rgba(100, 100, 122, 0.06)",
    "field-focus-ring-dark":  "0 0 0 4px rgba(167, 167, 204, 0.10)"
  },

  "components": {
    "field": {
      "height": 52,
      "padding-x": 14,
      "icon-gap": 12,
      "icon-size": 18,
      "border-width-idle": 1.5,
      "border-width-focus": 1.5,
      "label-margin-bottom": 8,
      "error-margin-top": 6,
      "valid-badge-size": 20
    },
    "button-primary": {
      "height": 54,
      "transform-hover": "translateY(-1px)"
    },
    "icon-button": {
      "size": 40
    },
    "loader": {
      "width": 120,
      "height": 3,
      "indicator-width-pct": 40
    },
    "strength-meter": {
      "bar-height": 3,
      "bars": 4,
      "gap": 4
    }
  },

  "animations": {
    "logo-entry": {
      "duration-ms": 1100,
      "easing": "cubic-bezier(0.2, 0.9, 0.25, 1)",
      "from": { "scale": 0.6, "translateY": 20, "blur-px": 8, "opacity": 0 },
      "to":   { "scale": 1.0, "translateY": 0,  "blur-px": 0, "opacity": 1 }
    },
    "check-draw": {
      "delay-ms": 400,
      "duration-ms": 700,
      "easing": "cubic-bezier(0.2, 0.7, 0.2, 1)",
      "technique": "stroke-dashoffset 160 → 0"
    },
    "wordmark-in": {
      "delay-ms": 350,
      "duration-ms": 900,
      "easing": "cubic-bezier(0.2, 0.9, 0.25, 1)",
      "from": { "translateY": 14, "opacity": 0, "tracking": "0.02em" },
      "to":   { "translateY": 0,  "opacity": 1, "tracking": "-0.02em" }
    },
    "tagline-in": {
      "delay-ms": 650,
      "duration-ms": 700,
      "easing": "ease",
      "from": { "translateY": 6, "opacity": 0 },
      "to":   { "translateY": 0, "opacity": 1 }
    },
    "particle-float": {
      "duration-ms": 2400,
      "loop": true,
      "stagger-ms": 80,
      "easing": "ease-in-out",
      "particles": 7
    },
    "halo-pulse": {
      "duration-ms": 4400,
      "loop": true,
      "rings": 3,
      "stagger-ms": 1100,
      "easing": "ease-out",
      "from": { "scale": 0.6, "opacity": 0.5 },
      "to":   { "scale": 1.6, "opacity": 0 }
    },
    "loader-slide": {
      "duration-ms": 1600,
      "loop": true,
      "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "field-focus-transition-ms": 180,
    "button-transform-transition-ms": 140
  },

  "copy": {
    "es": {
      "splash-tagline": "Hábitos · Bienestar · Tú",
      "wordmark": ["Better", "Life"],

      "signup-title":    "Crea tu cuenta",
      "signup-subtitle": "Empieza tu camino hacia mejores hábitos.",
      "signup-cta":      "Crear cuenta",
      "signup-footer":   "¿Ya tienes cuenta?",
      "signup-footer-link": "Inicia sesión",
      "signup-terms":    "Al continuar, aceptas nuestros Términos y Política de privacidad.",

      "login-title":    "Bienvenido de vuelta",
      "login-subtitle": "Continuemos donde lo dejaste.",
      "login-cta":      "Iniciar sesión",
      "login-forgot":   "¿Olvidaste tu contraseña?",
      "login-footer":   "¿No tienes cuenta?",
      "login-footer-link": "Regístrate",

      "field-name":     "Nombre",
      "field-email":    "Email",
      "field-password": "Contraseña",

      "ph-name":     "Tu nombre",
      "ph-email":    "tucorreo@ejemplo.com",
      "ph-password-signup": "Mínimo 8 caracteres",
      "ph-password-login":  "Tu contraseña",

      "err-name":  "Demasiado corto",
      "err-email": "Correo no válido",

      "strength": ["", "Débil", "Aceptable", "Buena", "Excelente"]
    }
  },

  "validation": {
    "name":  { "min-length": 2 },
    "email": { "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$" },
    "password-signup": { "min-strength-score": 2 },
    "password-login":  { "min-length": 6 },
    "strength-rules": [
      "length >= 8 → +1",
      "has uppercase → +1",
      "has digit → +1",
      "has symbol → +1",
      "length >= 12 → +1 (capped at 4)"
    ]
  }
}
